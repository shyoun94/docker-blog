---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>{SITE_TITLE} 👋</h1>
				<p>{SITE_DESCRIPTION}</p>
				<p>
					프론트엔드 2년차 개발자가 공부하며 막힌 지점과 풀어낸 과정을 기록합니다.
					지금은 <strong>도커</strong>를 처음부터 차근차근 정리하는 중이에요.
				</p>
			</section>

			<section class="recent">
				<h2>최근 글</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`${base}blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											class="thumb"
											width={140}
											height={90}
											src={post.data.heroImage}
											alt=""
										/>
									)}
									<div class="meta">
										<span class="title">{post.data.title}</span>
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
								</a>
							</li>
						))
					}
				</ul>
				<p class="more">
					<a href={`${base}blog/`}>전체 글 보기 →</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
	<style>
		.intro {
			margin-bottom: 2.5rem;
		}
		.intro h1 {
			margin-bottom: 0.4em;
		}
		.intro p {
			color: rgb(var(--gray-dark));
		}
		.recent h2 {
			margin-bottom: 1rem;
		}
		.recent ul {
			list-style: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}
		.recent li a {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding: 0.75rem;
			border-radius: 12px;
			text-decoration: none;
			color: inherit;
			transition: background 0.2s ease;
		}
		.recent li a:hover {
			background: rgb(var(--gray-light));
		}
		.thumb {
			border-radius: 8px;
			object-fit: cover;
			flex-shrink: 0;
		}
		.meta {
			display: flex;
			flex-direction: column;
			gap: 0.2rem;
		}
		.meta .title {
			font-weight: 700;
			color: rgb(var(--black));
			line-height: 1.3;
		}
		.meta .date {
			font-size: 0.85rem;
			color: rgb(var(--gray));
		}
		.recent li a:hover .title {
			color: rgb(var(--accent));
		}
		.more {
			margin-top: 1.25rem;
		}
		.more a {
			font-weight: 600;
		}
	</style>
</html>
